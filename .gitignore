# Python caches and virtual environments
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/

# Build and packaging output
build/
dist/
site/
*.egg-info/
*.egg
*.spec

# Test, lint, and coverage output
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Local configuration and secrets
.env
.env.*
!.env.example
*.log

# IDE and OS files
.idea/
.vscode/
.DS_Store
Thumbs.db

# Runtime outputs
runs/
outputs/
logs/
reports/*
!reports/.gitkeep
!reports/README.md

# Data and model artifacts
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
models/registry.json
*.pt
*.pth
*.onnx
*.engine
*.weights
*.pb
*.mlmodel
*.torchscript
*.tflite
*.h5

# Local media should not be committed by default
*.jpg
*.jpeg
*.png
*.bmp
*.tif
*.tiff
*.webp
*.gif
*.mp4
*.mov
*.avi
!examples/images/sample.jpg
!assets/**/*.svg
